---
const base = import.meta.env.BASE_URL;
---

<footer class="main-footer">
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-col">
        <h3>CSCO</h3>
        <p>Excellence & Élégance</p>
        <p class="footer-tagline">by Jean-Philippe Guidicili</p>
      </div>

      <div class="footer-col">
        <h4>Navigation</h4>
        <ul>
          <li><a href={base + '/vodka'}>Vodka HOVERLA</a></li>
          <li><a href={base + '/cigares'}>Cigares Mont Noir</a></li>
          <li><a href={base + '/coffrets'}>Coffrets</a></li>
          <li><a href={base + '/contact'}>Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>HOVERLA Vodka</h4>
        <ul>
          <li><a href="https://www.hoverlavodka.com" target="_blank" rel="noopener">www.hoverlavodka.com</a></li>
          <li><a href="mailto:contact@hoverlavodka.com">contact@hoverlavodka.com</a></li>
        </ul>
        <div class="social-links">
          <a href="https://www.instagram.com/hoverla.vodka" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://www.facebook.com/hoverlavodka" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-legal">
      <p class="legal-warning">L'ABUS D'ALCOOL EST DANGEREUX POUR LA SANTÉ. À CONSOMMER AVEC MODÉRATION.</p>
      <p class="copyright">&copy; {new Date().getFullYear()} CSCO. Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    margin-top: 80px;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px 30px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
    margin-bottom: 40px;
  }

  .footer-col h3 {
    font-size: 24px;
    margin-bottom: 10px;
  }

  .footer-col h4 {
    font-size: 16px;
    color: var(--gold);
    margin-bottom: 15px;
    letter-spacing: 0.05em;
  }

  .footer-col p {
    color: var(--white-2);
    font-size: 14px;
    line-height: 1.6;
  }

  .footer-tagline {
    font-style: italic;
    color: var(--text-muted);
    margin-top: 5px;
  }

  .footer-col ul {
    list-style: none;
  }

  .footer-col ul li {
    margin-bottom: 10px;
  }

  .footer-col ul li a {
    color: var(--white-2);
    font-size: 14px;
    transition: color 0.3s ease;
  }

  .footer-col ul li a:hover {
    color: var(--gold);
  }

  .social-links {
    display: flex;
    gap: 15px;
    margin-top: 15px;
  }

  .social-links a {
    color: var(--gold);
    transition: color 0.3s ease;
  }

  .social-links a:hover {
    color: var(--gold-light);
  }

  .footer-legal {
    border-top: 1px solid var(--border);
    padding-top: 30px;
    text-align: center;
  }

  .legal-warning {
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 15px;
  }

  .copyright {
    color: var(--text-muted);
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .footer-container {
      padding: 40px 20px 20px;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
</style>
