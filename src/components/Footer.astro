---
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__divider"></div>
  
  <div class="footer__container">
    <div class="footer__grid">
      <!-- Colonne 1: Branding -->
      <div class="footer__brand">
        <h3 class="footer__logo">CSCO</h3>
        <p class="footer__tagline">Excellence & Élégance</p>
      </div>

      <!-- Colonne 2: Navigation -->
      <div class="footer__nav">
        <h4 class="footer__title">Navigation</h4>
        <ul class="footer__links">
          <li><a href={base}>Accueil</a></li>
          <li><a href={`${base}vodka`}>Vodka HOVERLA</a></li>
          <li><a href={`${base}cigares`}>Cigares Mont Noir</a></li>
          <li><a href={`${base}coffrets`}>Coffrets</a></li>
          <li><a href={`${base}contact`}>Contact</a></li>
        </ul>
      </div>

      <!-- Colonne 3: Social & Contact -->
      <div class="footer__social">
        <h4 class="footer__title">Suivez-nous</h4>
        <ul class="footer__links">
          <li><a href="https://instagram.com/hoverla.vodka" target="_blank" rel="noopener">Instagram @hoverla.vodka</a></li>
          <li><a href="https://facebook.com/hoverlavodka" target="_blank" rel="noopener">Facebook</a></li>
          <li><a href="mailto:contact@csco-spirits.com">contact@csco-spirits.com</a></li>
        </ul>
      </div>
    </div>

    <!-- Mention légale alcool -->
    <div class="footer__legal">
      <p>L'abus d'alcool est dangereux pour la santé. À consommer avec modération.</p>
      <p>© {currentYear} CSCO by Jean-Philippe Guidicili. Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #080808;
    color: var(--white-dim);
    padding: 80px 0 40px;
  }

  .footer__divider {
    width: 100%;
    height: 1px;
    background: var(--gold);
    margin-bottom: 80px;
  }

  .footer__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 60px;
  }

  .footer__brand {
    max-width: 400px;
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .footer__tagline {
    font-family: var(--font-display);
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    color: var(--white-dim);
  }

  .footer__title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__links li {
    margin-bottom: 12px;
  }

  .footer__links a {
    font-size: 14px;
    font-weight: 300;
    color: var(--white-dim);
    transition: color 0.3s ease;
  }

  .footer__links a:hover {
    color: var(--gold);
  }

  .footer__legal {
    padding-top: 40px;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer__legal p {
    font-size: 11px;
    font-weight: 300;
    color: rgba(245, 242, 236, 0.4);
    margin-bottom: 8px;
  }

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .footer__brand {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 60px 0 32px;
    }

    .footer__container {
      padding: 0 24px;
    }

    .footer__divider {
      margin-bottom: 60px;
    }

    .footer__logo {
      font-size: 36px;
    }

    .footer__grid {
      gap: 32px;
      margin-bottom: 40px;
    }
  }
</style>
