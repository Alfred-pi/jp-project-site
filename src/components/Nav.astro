---
const { current = "/" } = Astro.props;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}`, label: "Accueil" },
  { href: `${base}vodka`, label: "Vodka" },
  { href: `${base}cigares`, label: "Cigares" },
  { href: `${base}coffrets`, label: "Coffrets" },
  { href: `${base}contact`, label: "Contact" },
];
---

<nav class="nav">
  <div class="nav__container">
    <a href={base} class="nav__logo">CSCO</a>
    
    <ul class="nav__links">
      {links.map(link => (
        <li>
          <a 
            href={link.href} 
            class:list={["nav__link", { active: current === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button class="nav__menu-toggle" id="menu-toggle">
      <span>Menu</span>
    </button>
  </div>

  <!-- Mobile Menu Fullscreen -->
  <div class="nav__mobile" id="mobile-menu">
    <button class="nav__mobile-close" id="menu-close">×</button>
    <ul class="nav__mobile-links">
      {links.map(link => (
        <li>
          <a href={link.href} class="nav__mobile-link">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(8, 8, 8, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .nav__container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 24px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 0.3em;
    color: var(--gold);
    transition: color 0.3s ease;
  }

  .nav__logo:hover {
    color: var(--gold-light);
  }

  .nav__links {
    display: flex;
    gap: 48px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245, 242, 236, 0.8);
    transition: color 0.3s ease;
    position: relative;
  }

  .nav__link:hover,
  .nav__link.active {
    color: var(--gold);
  }

  .nav__link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--gold);
  }

  .nav__menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--white);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: var(--font-body);
    transition: color 0.3s ease;
  }

  .nav__menu-toggle:hover {
    color: var(--gold);
  }

  /* Mobile Menu */
  .nav__mobile {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: var(--bg);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .nav__mobile.active {
    opacity: 1;
    pointer-events: all;
  }

  .nav__mobile-close {
    position: absolute;
    top: 32px;
    right: 40px;
    background: none;
    border: none;
    color: var(--white);
    font-size: 48px;
    font-weight: 300;
    cursor: pointer;
    line-height: 1;
    transition: color 0.3s ease;
  }

  .nav__mobile-close:hover {
    color: var(--gold);
  }

  .nav__mobile-links {
    list-style: none;
    text-align: center;
    padding: 0;
    margin: 0;
  }

  .nav__mobile-links li {
    margin-bottom: 32px;
  }

  .nav__mobile-link {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 300;
    color: var(--white);
    transition: color 0.3s ease;
  }

  .nav__mobile-link:hover {
    color: var(--gold);
  }

  @media (max-width: 1024px) {
    .nav__links {
      display: none;
    }

    .nav__menu-toggle {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .nav__container {
      padding: 20px 24px;
    }

    .nav__logo {
      font-size: 20px;
      letter-spacing: 0.2em;
    }

    .nav__mobile-link {
      font-size: 32px;
    }
  }
</style>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.add('active');
  });

  menuClose?.addEventListener('click', () => {
    mobileMenu?.classList.remove('active');
  });

  // Close menu on link click
  const mobileLinks = document.querySelectorAll('.nav__mobile-link');
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('active');
    });
  });
</script>
