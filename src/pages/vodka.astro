---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const saveurs = [
  {
    name: 'Original',
    color: '#C8A84E',
    description: 'Pure expression du blé des Carpates. Cristalline et élégante.',
  },
  {
    name: 'Honey',
    color: '#D4A24E',
    description: 'Miel artisanal des montagnes. Douceur authentique.',
  },
  {
    name: 'Pepper',
    color: '#8B4513',
    description: 'Poivre noir subtil. Caractère affirmé.',
  },
  {
    name: 'Cherry',
    color: '#A52A2A',
    description: 'Cerise griotte. Équilibre parfait entre fruit et finesse.',
  },
  {
    name: 'Cranberry',
    color: '#DC143C',
    description: 'Canneberge sauvage. Fraîcheur vivifiante.',
  },
  {
    name: 'Birch',
    color: '#8FBC8F',
    description: 'Sève de bouleau. Tradition ancestrale.',
  },
  {
    name: 'Horseradish',
    color: '#F5F5DC',
    description: 'Raifort piquant. Pour les audacieux.',
  },
];
---

<Layout title="HOVERLA — Vodka Artisanale Ukrainienne">
  <!-- HERO -->
  <section class="hero-vodka">
    <div class="hero-vodka__bg"></div>
    <div class="hero-vodka__content">
      <div class="t-label">Vodka artisanale ukrainienne</div>
      <h1 class="t-hero">HOVERLA</h1>
      <p class="hero-vodka__tagline">Sept saveurs · Une excellence</p>
    </div>
    <div class="hero-vodka__lineup">
      <img src={`${base}/images/hoverla-lineup-nobg.png`} alt="HOVERLA Lineup" />
    </div>
  </section>

  <!-- INTRO -->
  <section class="intro-vodka">
    <div class="intro-vodka__inner">
      <div class="intro-vodka__left">
        <h2 class="t-section">L'esprit<br/>des Carpates</h2>
      </div>
      <div class="intro-vodka__right">
        <div class="divider-gold"></div>
        <p class="t-body">
          HOVERLA tire son nom du plus haut sommet des Carpates ukrainiennes, 
          symbole de pureté et d'excellence. Distillée selon des méthodes traditionnelles 
          transmises de génération en génération, notre vodka incarne la rencontre entre 
          un terroir préservé et un savoir-faire artisanal exceptionnel.
        </p>
        <p class="t-body">
          Chaque bouteille célèbre l'eau cristalline des sources de montagne et 
          le blé noble des plaines fertiles. Une vodka qui se déguste, se savoure, 
          et révèle toute la richesse d'un patrimoine authentique.
        </p>
      </div>
    </div>
  </section>

  <!-- LES 7 SAVEURS -->
  <section class="saveurs">
    <div class="saveurs__header">
      <div class="t-label">Les sept expressions</div>
      <h2 class="t-section">Nos saveurs</h2>
    </div>
    
    <div class="saveurs__grid">
      {saveurs.map((saveur) => (
        <div class="saveur-card">
          <div class="saveur-card__accent" style={`background: ${saveur.color};`}></div>
          <h3 class="saveur-card__name">{saveur.name}</h3>
          <p class="saveur-card__desc">{saveur.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PROCESS -->
  <section class="process">
    <div class="process__inner">
      <div class="t-label">Artisanat</div>
      <h2 class="t-section">Une distillation<br/>d'exception</h2>
      <div class="divider-gold"></div>
      
      <div class="process__steps">
        <div class="process__step">
          <div class="process__step-number">01</div>
          <h3 class="process__step-title">Sélection du blé</h3>
          <p class="process__step-desc">
            Blé pur cultivé dans les plaines fertiles d'Ukraine, 
            sélectionné pour sa qualité exceptionnelle.
          </p>
        </div>
        
        <div class="process__step">
          <div class="process__step-number">02</div>
          <h3 class="process__step-title">Eau de source</h3>
          <p class="process__step-desc">
            Eau cristalline puisée dans les sources des Carpates, 
            naturellement pure et minérale.
          </p>
        </div>
        
        <div class="process__step">
          <div class="process__step-number">03</div>
          <h3 class="process__step-title">Distillation traditionnelle</h3>
          <p class="process__step-desc">
            Triple distillation selon des méthodes artisanales 
            transmises depuis plusieurs générations.
          </p>
        </div>
        
        <div class="process__step">
          <div class="process__step-number">04</div>
          <h3 class="process__step-title">Aromatisation naturelle</h3>
          <p class="process__step-desc">
            Infusions d'ingrédients naturels sélectionnés 
            pour créer sept expressions uniques.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA CONTACT -->
  <section class="cta-vodka">
    <div class="cta-vodka__inner">
      <div class="t-label">Distribution exclusive</div>
      <h2 class="t-section">Distribuée en Suisse<br/>par Suisse Prestige</h2>
      <a href={`${base}/contact`} class="btn-primary">Nous contacter</a>
    </div>
  </section>
</Layout>

<style>
  /* ========================================
     HERO VODKA
     ======================================== */
  .hero-vodka {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 10vw 80px;
    overflow: hidden;
  }

  .hero-vodka__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #080808 0%, #0D0A06 100%);
    z-index: -1;
  }

  .hero-vodka__content {
    text-align: center;
    margin-bottom: 80px;
    z-index: 1;
  }

  .hero-vodka__tagline {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--white-60);
    margin-top: 24px;
  }

  .hero-vodka__lineup {
    max-width: 1200px;
    width: 100%;
    padding: 0 32px;
  }

  .hero-vodka__lineup img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.5));
  }

  /* ========================================
     INTRO VODKA
     ======================================== */
  .intro-vodka {
    padding: 160px 10vw;
    background: var(--black);
  }

  .intro-vodka__inner {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .intro-vodka__right {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ========================================
     SAVEURS
     ======================================== */
  .saveurs {
    padding: 160px 10vw;
    background: var(--black-warm);
  }

  .saveurs__header {
    text-align: center;
    margin-bottom: 80px;
  }

  .saveurs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .saveur-card {
    position: relative;
    padding: 40px 32px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(200, 168, 78, 0.15);
    border-radius: 4px;
    transition: all 0.4s ease;
  }

  .saveur-card:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--gold);
    transform: translateY(-4px);
  }

  .saveur-card__accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    border-radius: 4px 4px 0 0;
  }

  .saveur-card__name {
    font-family: var(--display);
    font-weight: 300;
    font-size: 32px;
    color: var(--white);
    margin-bottom: 16px;
  }

  .saveur-card__desc {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--white-60);
  }

  /* ========================================
     PROCESS
     ======================================== */
  .process {
    padding: 160px 10vw;
    background: var(--black);
    text-align: center;
  }

  .process__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .process__steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 60px;
    margin-top: 80px;
  }

  .process__step {
    text-align: left;
  }

  .process__step-number {
    font-family: var(--display);
    font-weight: 300;
    font-size: 64px;
    color: var(--gold);
    opacity: 0.3;
    margin-bottom: 16px;
  }

  .process__step-title {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }

  .process__step-desc {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--white-60);
  }

  /* ========================================
     CTA VODKA
     ======================================== */
  .cta-vodka {
    padding: 120px 10vw;
    background: var(--black-warm);
    border-top: 1px solid var(--gold-dim);
    text-align: center;
  }

  .cta-vodka__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-vodka__inner h2 {
    margin: 24px 0 48px;
  }

  /* ========================================
     MOBILE
     ======================================== */
  @media (max-width: 768px) {
    .hero-vodka {
      padding: 100px 32px 60px;
    }

    .hero-vodka__lineup {
      padding: 0 16px;
    }

    .intro-vodka {
      padding: 80px 32px;
    }

    .intro-vodka__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .saveurs {
      padding: 80px 32px;
    }

    .saveurs__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .process {
      padding: 80px 32px;
    }

    .process__steps {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .cta-vodka {
      padding: 80px 32px;
    }
  }
</style>
