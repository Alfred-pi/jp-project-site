---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="HOVERLA — Vodka Artisanale Ukrainienne" description="Vodka ukrainienne d'exception. Sept saveurs uniques, distillation artisanale.">
  <Nav current={`${base}/vodka`} />

  <!-- Hero Full-Bleed -->
  <section class="hero">
    <div class="hero__image">
      <img src={`${base}/images/hoverla-gamme-bar.jpg`} alt="Gamme HOVERLA" class="img-cover" />
    </div>
    <div class="hero__overlay">
      <h1 class="hero__title fade-up">HOVERLA</h1>
      <p class="hero__subtitle fade-up">Vodka Artisanale Ukrainienne</p>
    </div>
    <div class="scroll-indicator">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 5v14m0 0l-7-7m7 7l7-7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </section>

  <!-- Section Histoire (2 colonnes) -->
  <section class="histoire section-padding">
    <div class="container">
      <div class="histoire__grid">
        <div class="histoire__text">
          <p class="histoire__quote fade-up">
            « Au sommet des Carpates, où le temps s'arrête, naît une vodka d'exception. »
          </p>
          <div class="divider fade-up"></div>
          <p class="fade-up">
            HOVERLA tire son nom du plus haut sommet d'Ukraine. Chaque bouteille incarne la pureté des glaciers et le savoir-faire ancestral des distillateurs ukrainiens.
          </p>
          <p class="fade-up">
            Distillée cinq fois à partir de blé d'hiver sélectionné, filtrée au charbon de bouleau, HOVERLA révèle une palette aromatique unique grâce à ses sept infusions naturelles.
          </p>
        </div>
        <div class="histoire__image">
          <img src={`${base}/images/hoverla-mignonnettes-gamme.jpg`} alt="Mignonnettes HOVERLA" />
        </div>
      </div>
    </div>
  </section>

  <!-- Section Dégustation (3 colonnes) -->
  <section class="degustation section-padding">
    <div class="container">
      <h2 class="degustation__title fade-up">L'Art de la Dégustation</h2>
      <div class="degustation__grid">
        <div class="degustation__col fade-up">
          <div class="degustation__divider"></div>
          <h3>Nez</h3>
          <p>Arômes délicats et purs, chaque saveur révèle sa personnalité dès les premières notes olfactives.</p>
        </div>
        <div class="degustation__col fade-up">
          <div class="degustation__divider"></div>
          <h3>Bouche</h3>
          <p>Texture soyeuse et équilibrée. La quintuple distillation garantit une rondeur exceptionnelle.</p>
        </div>
        <div class="degustation__col fade-up">
          <div class="degustation__divider"></div>
          <h3>Finale</h3>
          <p>Persistance élégante, sans amertume. Les arômes naturels s'expriment en longueur.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section Gamme (identique accueil) -->
  <section class="gamme section-padding">
    <div class="container">
      <h2 class="gamme__title fade-up">La Collection</h2>
      <div class="gamme__grid">
        <!-- Pure -->
        <div class="gamme__card fade-up">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <polygon points="40,4 76,40 40,76 4,40" fill="none" stroke="#C8A84E" stroke-width="1.5"/>
          </svg>
          <h3 class="gamme__name">Pure</h3>
          <p class="gamme__desc">Caractère authentique</p>
        </div>

        <!-- Apple -->
        <div class="gamme__card fade-up">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <polygon points="40,4 76,40 40,76 4,40" fill="none" stroke="#7BC67E" stroke-width="1.5"/>
          </svg>
          <h3 class="gamme__name">Apple</h3>
          <p class="gamme__desc">Fraîcheur fruitée</p>
        </div>

        <!-- Pineapple -->
        <div class="gamme__card fade-up">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <polygon points="40,4 76,40 40,76 4,40" fill="none" stroke="#F5C842" stroke-width="1.5"/>
          </svg>
          <h3 class="gamme__name">Pineapple</h3>
          <p class="gamme__desc">Exotisme tropical</p>
        </div>

        <!-- Acai Berry -->
        <div class="gamme__card fade-up">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <polygon points="40,4 76,40 40,76 4,40" fill="none" stroke="#7B4FA6" stroke-width="1.5"/>
          </svg>
          <h3 class="gamme__name">Acai Berry</h3>
          <p class="gamme__desc">Intensité sauvage</p>
        </div>

        <!-- Peach -->
        <div class="gamme__card fade-up">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <polygon points="40,4 76,40 40,76 4,40" fill="none" stroke="#F4A460" stroke-width="1.5"/>
          </svg>
          <h3 class="gamme__name">Peach</h3>
          <p class="gamme__desc">Douceur veloutée</p>
        </div>

        <!-- Coconut -->
        <div class="gamme__card fade-up">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <polygon points="40,4 76,40 40,76 4,40" fill="none" stroke="#8B6347" stroke-width="1.5"/>
          </svg>
          <h3 class="gamme__name">Coconut</h3>
          <p class="gamme__desc">Onctuosité crémeuse</p>
        </div>

        <!-- Red Berry -->
        <div class="gamme__card fade-up">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <polygon points="40,4 76,40 40,76 4,40" fill="none" stroke="#C0392B" stroke-width="1.5"/>
          </svg>
          <h3 class="gamme__name">Red Berry</h3>
          <p class="gamme__desc">Élégance acidulée</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta section-padding">
    <div class="container container--narrow">
      <div class="cta__content fade-up">
        <span class="label">DISPONIBLE</span>
        <h2>Où trouver HOVERLA ?</h2>
        <p>Nos vodkas sont disponibles en boutiques spécialisées et en ligne.</p>
        <a href={`${base}/contact`} class="btn btn-gold">Nous contacter</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ========================================
     HERO FULL-BLEED
     ======================================== */
  .hero {
    position: relative;
    height: 90vh;
    margin-top: 72px;
    overflow: hidden;
  }

  .hero__image {
    width: 100%;
    height: 100%;
  }

  .hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(8, 8, 8, 0.4);
    text-align: center;
  }

  .hero__title {
    font-size: clamp(64px, 10vw, 120px);
    color: var(--white);
    margin-bottom: 16px;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ========================================
     SECTION HISTOIRE
     ======================================== */
  .histoire {
    background: var(--bg);
  }

  .histoire__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .histoire__quote {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-style: italic;
    font-weight: 300;
    line-height: 1.4;
    color: var(--white);
    margin-bottom: 32px;
  }

  .histoire__text p {
    margin-bottom: 24px;
  }

  .histoire__image img {
    width: 100%;
    height: auto;
  }

  /* ========================================
     SECTION DÉGUSTATION
     ======================================== */
  .degustation {
    background: var(--bg-warm);
  }

  .degustation__title {
    text-align: center;
    margin-bottom: 80px;
  }

  .degustation__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
  }

  .degustation__col {
    text-align: center;
  }

  .degustation__divider {
    width: 60px;
    height: 1px;
    background: var(--gold);
    margin: 0 auto 24px;
  }

  .degustation__col h3 {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 300;
    color: var(--white);
    margin-bottom: 16px;
  }

  .degustation__col p {
    font-size: 15px;
    line-height: 1.8;
  }

  /* ========================================
     SECTION GAMME
     ======================================== */
  .gamme {
    background: var(--bg);
  }

  .gamme__title {
    text-align: center;
    margin-bottom: 60px;
  }

  .gamme__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
  }

  .gamme__card {
    background: #111;
    height: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    transition: all 0.4s ease;
    border: 1px solid transparent;
  }

  .gamme__card:hover {
    background: #1a1a1a;
    border-color: var(--gold);
  }

  .gamme__name {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 300;
    color: var(--white);
    margin: 0;
  }

  .gamme__desc {
    font-size: 12px;
    font-weight: 300;
    color: var(--white-dim);
    margin: 0;
  }

  /* ========================================
     SECTION CTA
     ======================================== */
  .cta {
    background: var(--bg);
    text-align: center;
  }

  .cta__content h2 {
    margin: 16px 0 24px;
  }

  .cta__content p {
    margin-bottom: 32px;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 1024px) {
    .histoire__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .degustation__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      margin-top: 64px;
      height: 70vh;
    }

    .gamme__grid {
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .gamme__card {
      height: 280px;
    }
  }
</style>
