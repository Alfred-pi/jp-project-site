---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="HOVERLA — Vodka Artisanale Ukrainienne | CSCO">
  
  <!-- HERO -->
  <section class="hero-page">
    <img src={`${base}/images/hoverla-gamme-bar.jpg`} alt="Hoverla Vodka" class="hero-page__bg">
    <div class="hero-page__overlay"></div>
    <div class="hero-page__content">
      <h1 class="hero-page__title">HOVERLA</h1>
      <p class="hero-page__subtitle">Vodka artisanale des Carpates</p>
    </div>
  </section>

  <!-- HISTOIRE -->
  <section class="histoire">
    <div class="histoire__container">
      <p class="t-label">L'origine</p>
      <div class="divider-gold" style="margin: 32px 0;"></div>
      <h2 class="t-section" style="margin-bottom: 32px;">Née au cœur<br>des Carpates</h2>
      <div class="histoire__grid">
        <div class="histoire__text">
          <p>Au sommet des montagnes ukrainiennes, là où l'air est pur et l'eau cristalline, naît HOVERLA — une vodka qui porte le nom du plus haut sommet des Carpates.</p>
          <p>Distillée cinq fois pour une pureté absolue, filtrée au charbon actif, HOVERLA incarne l'excellence de la tradition ukrainienne et le savoir-faire artisanal.</p>
        </div>
        <div class="histoire__img">
          <img src={`${base}/images/bg-mountain.jpg`} alt="Carpates">
        </div>
      </div>
    </div>
  </section>

  <!-- LA GAMME -->
  <section class="gamme-detail">
    <div class="gamme-detail__container">
      <p class="t-label" style="margin-bottom: 60px;">7 expressions · Une signature</p>
      
      <div class="gamme-detail__grid">
        
        <div class="gamme-detail__item">
          <img src={`${base}/images/hoverla-official-1.jpg`} alt="Pure">
          <h3>Pure</h3>
          <p>L'essence même de la vodka. Pure, nette, élégante.</p>
        </div>

        <div class="gamme-detail__item">
          <img src={`${base}/images/hoverla-official-2.jpg`} alt="Apple">
          <h3>Apple</h3>
          <p>Notes de pomme verte fraîche et délicate.</p>
        </div>

        <div class="gamme-detail__item">
          <img src={`${base}/images/hoverla-official-3.jpg`} alt="Pineapple">
          <h3>Pineapple</h3>
          <p>Exotic et rafraîchissant, comme un voyage.</p>
        </div>

        <div class="gamme-detail__item">
          <img src={`${base}/images/hoverla-official-4.jpg`} alt="Acai Berry">
          <h3>Acai Berry</h3>
          <p>Profondeur fruitée avec une touche mystérieuse.</p>
        </div>

        <div class="gamme-detail__item">
          <img src={`${base}/images/hoverla-official-5.jpg`} alt="Peach">
          <h3>Peach</h3>
          <p>Douceur veloutée de pêche mûre.</p>
        </div>

        <div class="gamme-detail__item">
          <img src={`${base}/images/hoverla-official-6.jpg`} alt="Coconut">
          <h3>Coconut</h3>
          <p>Crémeuse et enveloppante, tropical chic.</p>
        </div>

        <div class="gamme-detail__item">
          <img src={`${base}/images/hoverla-official-7.jpg`} alt="Red Berry">
          <h3>Red Berry</h3>
          <p>Baies rouges intenses, caractère affirmé.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cta-final">
    <div class="cta-final__content">
      <h2 class="t-section" style="margin-bottom: 32px;">Découvrez nos coffrets</h2>
      <p class="t-body" style="max-width: 600px; margin: 0 auto 40px;">L'expérience HOVERLA dans des coffrets d'exception.</p>
      <a href={`${base}/coffrets`} class="btn-primary">Voir les coffrets</a>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero-page {
    position: relative;
    height: 90svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-page__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-page__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(8, 8, 8, 0.4);
    z-index: 1;
  }

  .hero-page__content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-page__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(72px, 10vw, 120px);
    line-height: 0.9;
    color: var(--white);
    margin-bottom: 16px;
  }

  .hero-page__subtitle {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* HISTOIRE */
  .histoire {
    background: var(--cream);
    padding: 120px 40px;
  }

  .histoire__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .histoire__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .histoire__text p {
    font-family: var(--body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.9;
    color: var(--text-warm);
    margin-bottom: 24px;
  }

  .histoire__img img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* GAMME DETAIL */
  .gamme-detail {
    background: var(--black);
    padding: 120px 40px;
  }

  .gamme-detail__container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .gamme-detail__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 60px;
  }

  .gamme-detail__item {
    text-align: center;
  }

  .gamme-detail__item img {
    height: 240px;
    width: auto;
    margin: 0 auto 24px;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
    transition: transform 0.5s ease;
  }

  .gamme-detail__item:hover img {
    transform: translateY(-12px);
  }

  .gamme-detail__item h3 {
    font-family: var(--display);
    font-size: 24px;
    font-weight: 300;
    color: var(--white);
    margin-bottom: 12px;
  }

  .gamme-detail__item p {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 300;
    color: var(--white-60);
    line-height: 1.6;
  }

  /* CTA FINAL */
  .cta-final {
    background: var(--cream);
    padding: 120px 40px;
    text-align: center;
  }

  .cta-final__content h2 {
    color: var(--text-dark);
  }

  .cta-final__content .t-body {
    color: var(--text-warm);
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .histoire__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .gamme-detail__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }
</style>
