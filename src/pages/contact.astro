---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — CSCO">
  <!-- HERO CONTACT -->
  <section class="hero-contact">
    <div class="hero-contact__content">
      <div class="t-label">Contactez-nous</div>
      <h1 class="t-section">Parlons<br/>excellence</h1>
      <div class="divider-gold" style="margin: 32px auto;"></div>
      <p class="t-body" style="max-width: 600px; margin: 0 auto; text-align: center;">
        Pour toute demande d'information, collaboration ou distribution, 
        notre équipe est à votre écoute.
      </p>
    </div>
  </section>

  <!-- CONTACT INFO -->
  <section class="contact-info">
    <div class="contact-info__inner">
      <!-- WhatsApp -->
      <div class="contact-card">
        <div class="contact-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
        </div>
        <h3 class="contact-card__title">WhatsApp</h3>
        <p class="contact-card__desc">Contactez-nous directement</p>
        <a href="https://wa.me/41791234567" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Envoyer un message
        </a>
      </div>

      <!-- Email -->
      <div class="contact-card">
        <div class="contact-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <h3 class="contact-card__title">Email</h3>
        <p class="contact-card__desc">Écrivez-nous</p>
        <a href="mailto:contact@hoverlavodka.com" class="btn-primary">
          contact@hoverlavodka.com
        </a>
      </div>

      <!-- Instagram -->
      <div class="contact-card">
        <div class="contact-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </div>
        <h3 class="contact-card__title">Instagram</h3>
        <p class="contact-card__desc">Suivez notre actualité</p>
        <a href="https://instagram.com/hoverla.vodka" target="_blank" rel="noopener noreferrer" class="btn-primary">
          @hoverla.vodka
        </a>
      </div>
    </div>
  </section>

  <!-- DISTRIBUTION -->
  <section class="distribution">
    <div class="distribution__inner">
      <div class="t-label">Distribution</div>
      <h2 class="t-section">Distributeur exclusif<br/>en Suisse</h2>
      <div class="divider-gold" style="margin: 32px auto;"></div>
      <p class="t-body" style="max-width: 700px; margin: 0 auto; text-align: center;">
        <strong style="color: var(--gold);">Suisse Prestige</strong> est le distributeur exclusif 
        de HOVERLA Vodka et Mont Noir Cigares sur le territoire suisse. 
        Pour toute demande de distribution, partenariat ou questions professionnelles, 
        contactez-nous via les moyens ci-dessus.
      </p>
    </div>
  </section>

  <!-- MAP (optionnel - placeholder) -->
  <section class="map-section">
    <div class="map-placeholder">
      <div class="map-placeholder__content">
        <div class="t-label">Suisse</div>
        <h3 class="t-section" style="font-size: clamp(32px, 4vw, 48px);">Nous sommes basés<br/>en Suisse romande</h3>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ========================================
     HERO CONTACT
     ======================================== */
  .hero-contact {
    padding: 160px 10vw 120px;
    background: var(--black);
    text-align: center;
  }

  .hero-contact__content {
    max-width: 800px;
    margin: 0 auto;
  }

  /* ========================================
     CONTACT INFO
     ======================================== */
  .contact-info {
    padding: 80px 10vw 120px;
    background: var(--black);
  }

  .contact-info__inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 48px 32px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(200, 168, 78, 0.15);
    border-radius: 4px;
    transition: all 0.4s ease;
  }

  .contact-card:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--gold);
    transform: translateY(-4px);
  }

  .contact-card__icon {
    color: var(--gold);
    margin-bottom: 24px;
  }

  .contact-card__title {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 12px;
  }

  .contact-card__desc {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 300;
    color: var(--white-60);
    margin-bottom: 32px;
  }

  .contact-card a.btn-primary {
    width: 100%;
    max-width: 280px;
  }

  /* ========================================
     DISTRIBUTION
     ======================================== */
  .distribution {
    padding: 120px 10vw;
    background: var(--black-warm);
    border-top: 1px solid var(--gold-dim);
    text-align: center;
  }

  .distribution__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  /* ========================================
     MAP SECTION
     ======================================== */
  .map-section {
    position: relative;
    overflow: hidden;
  }

  .map-placeholder {
    position: relative;
    min-height: 500px;
    background: linear-gradient(135deg, #0D0A06 0%, #080808 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .map-placeholder::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('/images/bg-mountain.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    filter: grayscale(1);
  }

  .map-placeholder__content {
    position: relative;
    text-align: center;
    z-index: 1;
    padding: 0 32px;
  }

  /* ========================================
     MOBILE
     ======================================== */
  @media (max-width: 768px) {
    .hero-contact {
      padding: 120px 32px 80px;
    }

    .contact-info {
      padding: 60px 32px 80px;
    }

    .contact-info__inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .distribution {
      padding: 80px 32px;
    }

    .map-placeholder {
      min-height: 400px;
    }
  }
</style>
