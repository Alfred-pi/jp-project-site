---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Contact — CSCO" description="Contactez-nous pour toute demande d'information ou commande de coffret d'exception.">
  <Nav current={`${base}contact`} />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__content fade-up">
        <span class="label">CONTACT</span>
        <h1>Nous Contacter</h1>
        <p class="hero__subtitle">Pour toute demande d'information, commande de coffret ou question sur nos produits, nous sommes à votre écoute.</p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact section-padding">
    <div class="container">
      <div class="contact__grid">
        <!-- Informations -->
        <div class="contact__info">
          <div class="contact__block fade-up">
            <h3>Email</h3>
            <p><a href="mailto:contact@csco-spirits.com">contact@csco-spirits.com</a></p>
          </div>

          <div class="contact__block fade-up">
            <h3>Téléphone</h3>
            <p><a href="tel:+33123456789">+33 1 23 45 67 89</a></p>
          </div>

          <div class="contact__block fade-up">
            <h3>Adresse</h3>
            <p>
              CSCO Spirits<br>
              123 Avenue des Champs-Élysées<br>
              75008 Paris, France
            </p>
          </div>

          <div class="contact__block fade-up">
            <h3>Réseaux Sociaux</h3>
            <div class="contact__social">
              <a href="https://instagram.com/hoverla.vodka" target="_blank" rel="noopener">Instagram</a>
              <a href="https://facebook.com/hoverlavodka" target="_blank" rel="noopener">Facebook</a>
            </div>
          </div>
        </div>

        <!-- Formulaire -->
        <div class="contact__form fade-up">
          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Ne pas remplir : <input name="bot-field" /></label>
            </p>

            <div class="form-group">
              <label for="name">Nom complet *</label>
              <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">Téléphone</label>
              <input type="tel" id="phone" name="phone" />
            </div>

            <div class="form-group">
              <label for="subject">Sujet *</label>
              <select id="subject" name="subject" required>
                <option value="">Choisissez un sujet</option>
                <option value="coffret">Commande de coffret</option>
                <option value="info-vodka">Information Vodka HOVERLA</option>
                <option value="info-cigares">Information Cigares Mont Noir</option>
                <option value="personnalisation">Coffret personnalisé</option>
                <option value="autre">Autre demande</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="6" required></textarea>
            </div>

            <button type="submit" class="btn btn-gold">Envoyer</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hidden {
    display: none;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: var(--bg);
    padding: 200px 0 120px;
    margin-top: 72px;
    text-align: center;
  }

  .hero__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    margin: 16px 0 24px;
  }

  .hero__subtitle {
    font-size: 16px;
    color: var(--white-dim);
  }

  /* ========================================
     SECTION CONTACT
     ======================================== */
  .contact {
    background: var(--bg);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
  }

  /* Informations */
  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .contact__block h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 300;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .contact__block p,
  .contact__block a {
    font-size: 15px;
    color: var(--white-dim);
    line-height: 1.8;
  }

  .contact__block a:hover {
    color: var(--gold);
  }

  .contact__social {
    display: flex;
    gap: 24px;
  }

  .contact__social a {
    font-size: 14px;
    color: var(--white-dim);
    transition: color 0.3s ease;
  }

  .contact__social a:hover {
    color: var(--gold);
  }

  /* Formulaire */
  .contact__form {
    background: rgba(255, 255, 255, 0.05);
    padding: 48px;
    border: 1px solid var(--border);
  }

  .form-group {
    margin-bottom: 24px;
  }

  .form-group label {
    display: block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    background: rgba(8, 8, 8, 0.6);
    border: 1px solid var(--border);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 14px;
    padding: 14px 16px;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__form button {
    width: 100%;
    margin-top: 16px;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 1024px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 160px 0 80px;
      margin-top: 64px;
    }

    .contact__form {
      padding: 32px 24px;
    }

    .contact__info {
      gap: 32px;
    }
  }
</style>
