---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="MONT NOIR — Cigares Premium | CSCO">
  
  <!-- HERO -->
  <section class="hero-page">
    <img src={`${base}/images/hoverla-cigare-gros-plan.jpg`} alt="Cigares Mont Noir" class="hero-page__bg">
    <div class="hero-page__overlay"></div>
    <div class="hero-page__content">
      <h1 class="hero-page__title">MONT NOIR</h1>
      <p class="hero-page__subtitle">Cigares Premium · Édition Exclusive</p>
    </div>
  </section>

  <!-- L'ÉDITION -->
  <section class="edition">
    <div class="edition__container">
      <p class="t-label">CSCO × Vegas Corporan</p>
      <div class="divider-gold" style="margin: 32px 0;"></div>
      <h2 class="t-section" style="margin-bottom: 32px;">Une collaboration<br>d'exception</h2>
      <div class="edition__content">
        <p>Mont Noir est né d'une rencontre entre l'excellence de CSCO et le savoir-faire artisanal de Vegas Corporan, maître cigare reconnu.</p>
        <p>Chaque cigare est roulé à la main, avec des feuilles de tabac sélectionnées parmi les meilleures plantations. Une expérience sensorielle unique qui complète parfaitement la dégustation de vodka HOVERLA.</p>
        <p>Mont Noir n'est pas simplement un cigare. C'est une déclaration d'intention, un moment suspendu, une célébration du raffinement.</p>
      </div>
    </div>
  </section>

  <!-- L'EXPÉRIENCE -->
  <section class="experience">
    <div class="experience__grid">
      <div class="experience__img">
        <img src={`${base}/images/csco-coffret-ouvert.jpg`} alt="Coffret Mont Noir">
      </div>
      <div class="experience__text">
        <h2 class="t-section" style="margin-bottom: 24px;">L'expérience<br>Mont Noir</h2>
        <p>Nos coffrets associent cigares premium et vodka artisanale dans un écrin pensé pour les connaisseurs.</p>
        <p>Chaque détail compte : du packaging élégant à la qualité des produits, tout est conçu pour offrir un moment inoubliable.</p>
        <a href={`${base}/coffrets`} class="btn-primary" style="margin-top: 32px;">Découvrir les coffrets</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-contact">
    <div class="cta-contact__content">
      <h2 class="t-section" style="margin-bottom: 24px;">Intéressé ?</h2>
      <p class="t-body" style="max-width: 600px; margin: 0 auto 40px;">Contactez-nous pour plus d'informations sur nos cigares et nos coffrets exclusifs.</p>
      <a href={`${base}/contact`} class="btn-primary">Nous contacter</a>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero-page {
    position: relative;
    height: 90svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-page__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-page__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(8, 8, 8, 0.5);
    z-index: 1;
  }

  .hero-page__content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-page__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(72px, 10vw, 120px);
    line-height: 0.9;
    color: var(--white);
    margin-bottom: 16px;
  }

  .hero-page__subtitle {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ÉDITION */
  .edition {
    background: var(--black-warm);
    padding: 120px 40px;
  }

  .edition__container {
    max-width: 800px;
    margin: 0 auto;
  }

  .edition__content p {
    font-family: var(--body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.9;
    color: var(--white-60);
    margin-bottom: 24px;
  }

  /* EXPÉRIENCE */
  .experience {
    background: var(--cream);
    padding: 120px 40px;
  }

  .experience__grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .experience__img img {
    width: 100%;
    height: auto;
    display: block;
  }

  .experience__text h2 {
    color: var(--text-dark);
  }

  .experience__text p {
    font-family: var(--body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.9;
    color: var(--text-warm);
    margin-bottom: 16px;
  }

  /* CTA CONTACT */
  .cta-contact {
    background: var(--black);
    padding: 120px 40px;
    text-align: center;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .experience__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
