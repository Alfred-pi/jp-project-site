---
import Layout from '../layouts/Layout.astro';
import AgeGate from '../components/AgeGate.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="CSCO — Excellence & Élégance" description="Vodka artisanale HOVERLA et cigares Mont Noir. L'art de l'excellence.">
  <AgeGate />
  <Nav current={base} />

  <!-- Hero Split Screen -->
  <section class="hero">
    <div class="hero__content">
      <div class="hero__text">
        <h1 class="fade-up">CSCO</h1>
        <p class="hero__subtitle fade-up">Excellence & Élégance</p>
        <div class="divider fade-up"></div>
        <a href="#vodka" class="btn btn-ghost fade-up">Découvrir</a>
      </div>
      <div class="hero__image">
        <img src={`${base}/images/csco-coffret-promo.jpg`} alt="CSCO - Coffret Premium" class="img-cover" />
      </div>
    </div>
    <div class="scroll-indicator">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 5v14m0 0l-7-7m7 7l7-7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </section>

  <!-- Section: La Maison (Full Bleed Texte) -->
  <section class="maison section-padding">
    <div class="container container--narrow">
      <p class="maison__quote fade-up">« Né au cœur des Carpates, forgé dans l'excellence. »</p>
      <div class="divider fade-up"></div>
      <p class="fade-up">CSCO incarne l'alliance parfaite entre tradition et raffinement. Chaque produit est le fruit d'un savoir-faire exceptionnel, pensé pour les connaisseurs qui recherchent l'excellence absolue.</p>
    </div>
  </section>

  <!-- Section: Vodka HOVERLA (Image Gauche) -->
  <div class="divider--full"></div>
  <section id="vodka" class="vodka">
    <div class="vodka__grid">
      <div class="vodka__image">
        <img src={`${base}/images/hoverla-gamme-bar.jpg`} alt="Gamme HOVERLA" class="img-cover" />
      </div>
      <div class="vodka__content">
        <span class="label fade-up">VODKA ARTISANALE</span>
        <h2 class="fade-up">HOVERLA</h2>
        <p class="fade-up">
          Une vodka ukrainienne d'exception, distillée selon des méthodes ancestrales. Sept saveurs uniques pour une palette aromatique incomparable.
        </p>
        <a href={`${base}/vodka`} class="btn btn-ghost fade-up">Découvrir la gamme</a>
      </div>
    </div>
  </section>

  <!-- Section: Gamme 7 saveurs (Bottles) -->
  <section class="gamme section-padding">
    <div class="container">
      <span class="label" style="display:block;text-align:center;margin-bottom:16px">LA GAMME</span>
      <h2 class="gamme__title fade-up" style="text-align:center;margin-bottom:60px">Sept expressions</h2>
      <div class="gamme__grid">
        {[
          { img: 'hoverla-official-1.jpg', name: 'Pure',      desc: 'Caractère authentique', color: '#C8A84E' },
          { img: 'hoverla-official-2.jpg', name: 'Apple',     desc: 'Fraîcheur fruitée',      color: '#7BC67E' },
          { img: 'hoverla-official-3.jpg', name: 'Pineapple', desc: 'Exotisme tropical',      color: '#F5C842' },
          { img: 'hoverla-official-4.jpg', name: 'Acai Berry',desc: 'Intensité sauvage',      color: '#7B4FA6' },
          { img: 'hoverla-official-5.jpg', name: 'Peach',     desc: 'Douceur veloutée',       color: '#F4A460' },
          { img: 'hoverla-official-6.jpg', name: 'Coconut',   desc: 'Onctuosité crémeuse',    color: '#8B6347' },
          { img: 'hoverla-official-7.jpg', name: 'Red Berry', desc: 'Élégance acidulée',      color: '#C0392B' },
        ].map(({ img, name, desc, color }) => (
          <div class="gamme__card fade-up">
            <div class="gamme__bottle-wrap">
              <img src={`${base}/images/${img}`} alt={`HOVERLA ${name}`} class="gamme__bottle" />
              <div class="gamme__color-bar" style={`background:${color}`}></div>
            </div>
            <h3 class="gamme__name">{name}</h3>
            <p class="gamme__desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section: Cigares (Fond Foncé Texturé) -->
  <section class="cigares">
    <div class="cigares__bg">
      <img src={`${base}/images/hoverla-cigare-gros-plan.jpg`} alt="Cigare Mont Noir" class="img-cover" />
    </div>
    <div class="cigares__content">
      <span class="label fade-up">EXCELLENCE CUBAINE</span>
      <h2 class="fade-up">MONT NOIR</h2>
      <p class="cigares__subtitle fade-up">Exclusivité CSCO × Vegas Corporan</p>
      <a href={`${base}/cigares`} class="btn btn-ghost fade-up">En savoir plus</a>
    </div>
  </section>

  <!-- Section: Coffrets (Asymétrique, fond crème) -->
  <section class="coffrets">
    <div class="coffrets__image">
      <img src={`${base}/images/csco-coffrets-cigare.jpg`} alt="Coffrets CSCO" class="img-cover" />
    </div>
    <div class="coffrets__content">
      <span class="label fade-up">PRESTIGE</span>
      <h2 class="fade-up">Coffrets d'Exception</h2>
      <p class="fade-up">
        Des écrins soigneusement composés pour célébrer les moments d'exception. L'union parfaite entre nos vodkas artisanales et nos cigares premium.
      </p>
      <a href={`${base}/coffrets`} class="btn btn-ghost fade-up">Découvrir</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ========================================
     HERO - SPLIT SCREEN
     ======================================== */
  .hero {
    min-height: 100vh;
    position: relative;
    margin-top: 72px; /* Nav offset */
  }

  .hero__content {
    display: grid;
    grid-template-columns: 45% 55%;
    min-height: 100vh;
  }

  .hero__text {
    background: var(--bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
  }

  .hero__subtitle {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
    margin-top: 16px;
    margin-bottom: 32px;
  }

  .hero__image {
    position: relative;
    overflow: hidden;
  }

  .hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ========================================
     SECTION: LA MAISON
     ======================================== */
  .maison {
    background: var(--bg);
    text-align: center;
  }

  .maison__quote {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-style: italic;
    font-weight: 300;
    line-height: 1.4;
    color: var(--white);
    margin-bottom: 40px;
  }

  /* ========================================
     SECTION: VODKA (Image Gauche)
     ======================================== */
  .vodka {
    background: var(--bg);
  }

  .vodka__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .vodka__image {
    height: 700px;
    overflow: hidden;
  }

  .vodka__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
  }

  .vodka__content h2 {
    margin: 16px 0 24px;
  }

  .vodka__content p {
    margin-bottom: 32px;
  }

  /* ========================================
     SECTION: GAMME (Cards)
     ======================================== */
  .gamme {
    background: var(--bg);
  }

  .gamme__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
  }

  .gamme__card {
    background: #111;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 32px 16px 24px;
    transition: all 0.4s ease;
    border: 1px solid transparent;
    cursor: default;
  }

  .gamme__card:hover {
    background: #1a1a1a;
    border-color: var(--gold);
    transform: translateY(-4px);
  }

  .gamme__bottle-wrap {
    position: relative;
    width: 100%;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gamme__bottle {
    height: 180px;
    width: auto;
    object-fit: contain;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.6));
    transition: transform 0.4s ease;
  }

  .gamme__card:hover .gamme__bottle {
    transform: scale(1.05);
  }

  .gamme__color-bar {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 40px;
    opacity: 0.7;
    border-radius: 1px;
  }

  .gamme__name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 300;
    color: var(--white);
    margin: 0;
    letter-spacing: 0.05em;
  }

  .gamme__desc {
    font-size: 11px;
    font-weight: 300;
    color: var(--white-dim);
    margin: 0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ========================================
     SECTION: CIGARES (Dark Atmospheric)
     ======================================== */
  .cigares {
    position: relative;
    background: var(--bg-warm);
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .cigares__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 40vh;
    opacity: 0.3;
  }

  .cigares__content {
    position: relative;
    z-index: 10;
    max-width: 600px;
    padding: 120px 40px;
  }

  .cigares__content h2 {
    margin: 16px 0;
  }

  .cigares__subtitle {
    font-size: 18px;
    color: var(--white-dim);
    margin-bottom: 32px;
  }

  /* ========================================
     SECTION: COFFRETS (Asymétrique)
     ======================================== */
  .coffrets {
    position: relative;
    background: var(--bg-cream);
    min-height: 600px;
    padding-left: 60%;
  }

  .coffrets__image {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 45%;
  }

  .coffrets__content {
    position: relative;
    z-index: 10;
    padding: 100px 60px;
    color: var(--bg);
  }

  .coffrets__content .label {
    color: var(--bg-warm);
  }

  .coffrets__content h2 {
    color: var(--bg);
    margin: 16px 0 24px;
  }

  .coffrets__content p {
    color: rgba(13, 10, 6, 0.7);
    margin-bottom: 32px;
  }

  .coffrets__content .btn {
    color: var(--bg);
    border-color: var(--bg);
  }

  .coffrets__content .btn:hover {
    background: var(--bg);
    color: var(--bg-cream);
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 1024px) {
    .hero__content {
      grid-template-columns: 1fr;
    }

    .hero__image {
      height: 50vh;
      order: -1;
    }

    .vodka__grid {
      grid-template-columns: 1fr;
    }

    .vodka__image {
      height: 400px;
    }

    .coffrets {
      padding-left: 0;
    }

    .coffrets__image {
      position: relative;
      width: 100%;
      height: 400px;
    }

    .coffrets__content {
      padding: 60px 40px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      margin-top: 64px;
    }

    .hero__text {
      padding: 60px 24px;
    }

    .vodka__content {
      padding: 60px 24px;
    }

    .gamme__grid {
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .gamme__card {
      height: 280px;
    }

    .cigares__content {
      padding: 80px 24px;
    }

    .coffrets__content {
      padding: 60px 24px;
    }
  }
</style>
