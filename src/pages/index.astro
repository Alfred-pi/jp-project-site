---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="CSCO — Excellence & Élégance">
  <!-- HERO FULLSCREEN -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="hero__content">
      <h1 class="hero__title">
        Excellence<br/>
        & Élégance
      </h1>
      <p class="hero__subtitle">Vodka artisanale · Cigares premium</p>
      <a href="#hoverla" class="hero__cta">
        <span>Découvrir</span>
        <svg class="hero__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 3v10M8 13l-4-4M8 13l4-4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- SECTION HOVERLA -->
  <section id="hoverla" class="section-hoverla">
    <div class="section-hoverla__inner">
      <div class="section-hoverla__text">
        <div class="t-label">Vodka artisanale ukrainienne</div>
        <h2 class="t-section">Née dans<br/>les Carpates</h2>
        <div class="divider-gold"></div>
        <p class="t-body">
          HOVERLA incarne l'excellence de la distillation ukrainienne. 
          Élaborée à partir de blé pur des Carpates et d'une eau de source cristalline, 
          notre vodka se décline en sept saveurs authentiques qui révèlent 
          la richesse d'un terroir préservé.
        </p>
        <a href={`${base}/vodka`} class="btn-primary">Explorer HOVERLA</a>
      </div>
      <div class="section-hoverla__image">
        <img src={`${base}/images/hoverla-official-1.jpg`} alt="HOVERLA Vodka" />
      </div>
    </div>
  </section>

  <!-- SECTION MONT NOIR -->
  <section class="section-mont-noir">
    <div class="section-mont-noir__inner">
      <div class="section-mont-noir__image">
        <img src={`${base}/images/bg-cigare.jpg`} alt="Mont Noir Cigares" />
      </div>
      <div class="section-mont-noir__text">
        <div class="t-label">Cigares premium</div>
        <h2 class="t-section">L'art<br/>du cigare</h2>
        <div class="divider-gold"></div>
        <p class="t-body">
          Mont Noir représente l'alliance entre tradition dominicaine 
          et excellence suisse. Une collaboration exclusive avec Vegas Corporan 
          qui célèbre le savoir-faire artisanal et la passion du cigare.
        </p>
        <a href={`${base}/cigares`} class="btn-primary">Découvrir Mont Noir</a>
      </div>
    </div>
  </section>

  <!-- SECTION CHIFFRES -->
  <section class="section-stats">
    <div class="section-stats__inner">
      <div class="stat">
        <div class="stat__number">7</div>
        <div class="stat__label">Saveurs artisanales</div>
      </div>
      <div class="stat">
        <div class="stat__number">100<span>%</span></div>
        <div class="stat__label">Artisanale</div>
      </div>
      <div class="stat">
        <div class="stat__number">1</div>
        <div class="stat__label">Distributeur exclusif Suisse</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ========================================
     HERO FULLSCREEN
     ======================================== */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('/images/bg-spirits-dark.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.4);
    z-index: -1;
  }

  .hero__content {
    text-align: center;
    z-index: 1;
    padding: 0 32px;
  }

  .hero__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(64px, 12vw, 140px);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--white);
    margin-bottom: 32px;
    animation: fadeUp 1s ease forwards;
  }

  .hero__subtitle {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--white-60);
    margin-bottom: 64px;
    animation: fadeUp 1s ease 0.2s forwards;
    opacity: 0;
    animation-fill-mode: forwards;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 16px 0;
    animation: fadeUp 1s ease 0.4s forwards;
    opacity: 0;
    animation-fill-mode: forwards;
    transition: transform 0.3s ease;
  }

  .hero__cta:hover {
    transform: translateY(8px);
  }

  .hero__arrow {
    animation: bounce 2s ease infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ========================================
     SECTION HOVERLA
     ======================================== */
  .section-hoverla {
    padding: 160px 10vw;
    background: var(--black);
  }

  .section-hoverla__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-hoverla__text {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .section-hoverla__image {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    background: linear-gradient(135deg, #1a1a1a 0%, #080808 100%);
    padding: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .section-hoverla__image img {
    width: 100%;
    max-width: 400px;
    height: auto;
    mix-blend-mode: multiply;
    filter: brightness(1.1) contrast(1.05);
  }

  /* ========================================
     SECTION MONT NOIR
     ======================================== */
  .section-mont-noir {
    padding: 160px 10vw;
    background: var(--black-warm);
  }

  .section-mont-noir__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-mont-noir__text {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .section-mont-noir__image {
    border-radius: 4px;
    overflow: hidden;
    height: 600px;
  }

  .section-mont-noir__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ========================================
     SECTION STATS
     ======================================== */
  .section-stats {
    padding: 120px 10vw;
    background: var(--black);
    border-top: 1px solid var(--gold-dim);
  }

  .section-stats__inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .stat__number {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(64px, 8vw, 96px);
    line-height: 1;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .stat__number span {
    font-size: 0.5em;
    color: var(--white-60);
  }

  .stat__label {
    font-family: var(--body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white-60);
  }

  /* ========================================
     MOBILE
     ======================================== */
  @media (max-width: 768px) {
    .hero__title {
      font-size: clamp(48px, 10vw, 72px);
    }

    .section-hoverla {
      padding: 80px 32px;
    }

    .section-hoverla__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .section-hoverla__image {
      padding: 40px;
    }

    .section-mont-noir {
      padding: 80px 32px;
    }

    .section-mont-noir__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .section-mont-noir__image {
      height: 400px;
    }

    /* Inverse order on mobile: text first */
    .section-mont-noir__text {
      order: 1;
    }

    .section-mont-noir__image {
      order: 2;
    }

    .section-stats {
      padding: 80px 32px;
    }

    .section-stats__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
