---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="CSCO — Excellence & Élégance">
  
  <!-- ========================================
       SECTION 1 — HERO ÉDITORIAL
       ======================================== -->
  <section class="hero">
    <div class="hero__text">
      <h1 class="hero__title">
        EXCELLENCE<br>& ÉLÉGANCE
      </h1>
      <div class="divider-gold"></div>
      <p class="hero__subtitle">Vodka · Cigares</p>
      <a href="#revelation" class="link-arrow">Découvrir</a>
    </div>
    <div class="hero__img">
      <img src={`${base}/images/csco-coffret-promo.jpg`} alt="CSCO Excellence" class="img-cover">
    </div>
  </section>

  <!-- ========================================
       SECTION 2 — RÉVÉLATION HOVERLA
       ======================================== -->
  <section id="revelation" class="revelation">
    <div class="revelation__text">
      <p class="t-label">Vodka artisanale ukrainienne</p>
      <div class="divider-gold" style="width: 60px; margin: 32px 0;"></div>
      <h2 class="revelation__title">HOVERLA</h2>
      <div class="revelation__content">
        <p>Née au cœur des Carpates.<br>Distillée cinq fois.<br>Filtrée au charbon actif.</p>
        <a href={`${base}/vodka`} class="link-arrow-gold">Découvrir la vodka</a>
      </div>
    </div>
    <div class="revelation__img">
      <img src={`${base}/images/hoverla-gamme-bar.jpg`} alt="Gamme Hoverla" class="img-cover">
    </div>
  </section>

  <!-- ========================================
       SECTION 3 — LA MAISON CSCO
       ======================================== -->
  <section class="maison">
    <blockquote class="maison__quote">
      « Né au cœur des Carpates,<br>forgé dans l'excellence. »
    </blockquote>
  </section>

  <!-- ========================================
       SECTION 4 — LA GAMME (horizontal scroll)
       ======================================== -->
  <section class="gamme">
    <p class="t-label" style="padding-left: 10vw; margin-bottom: 40px;">La gamme · 7 expressions</p>
    <div class="gamme__scroll" id="gamme-scroll">
      
      <div class="gamme__item">
        <img src={`${base}/images/hoverla-official-1.jpg`} alt="Pure" class="gamme__bottle">
        <p class="gamme__item-name">Pure</p>
        <div class="gamme__item-color" style="background: #D4AF37;"></div>
      </div>

      <div class="gamme__item">
        <img src={`${base}/images/hoverla-official-2.jpg`} alt="Apple" class="gamme__bottle">
        <p class="gamme__item-name">Apple</p>
        <div class="gamme__item-color" style="background: #8FBC8F;"></div>
      </div>

      <div class="gamme__item">
        <img src={`${base}/images/hoverla-official-3.jpg`} alt="Pineapple" class="gamme__bottle">
        <p class="gamme__item-name">Pineapple</p>
        <div class="gamme__item-color" style="background: #FFD700;"></div>
      </div>

      <div class="gamme__item">
        <img src={`${base}/images/hoverla-official-4.jpg`} alt="Acai Berry" class="gamme__bottle">
        <p class="gamme__item-name">Acai Berry</p>
        <div class="gamme__item-color" style="background: #6A5ACD;"></div>
      </div>

      <div class="gamme__item">
        <img src={`${base}/images/hoverla-official-5.jpg`} alt="Peach" class="gamme__bottle">
        <p class="gamme__item-name">Peach</p>
        <div class="gamme__item-color" style="background: #FFDAB9;"></div>
      </div>

      <div class="gamme__item">
        <img src={`${base}/images/hoverla-official-6.jpg`} alt="Coconut" class="gamme__bottle">
        <p class="gamme__item-name">Coconut</p>
        <div class="gamme__item-color" style="background: #8B4513;"></div>
      </div>

      <div class="gamme__item">
        <img src={`${base}/images/hoverla-official-7.jpg`} alt="Red Berry" class="gamme__bottle">
        <p class="gamme__item-name">Red Berry</p>
        <div class="gamme__item-color" style="background: #DC143C;"></div>
      </div>

    </div>
  </section>

  <!-- ========================================
       SECTION 5 — CIGARES MONT NOIR
       ======================================== -->
  <section class="cigares">
    <div class="cigares__text">
      <h2 class="cigares__title">CIGARES<br>MONT NOIR</h2>
      <div class="divider-gold"></div>
      <p class="cigares__subtitle">CSCO × Vegas Corporan</p>
      <p class="cigares__desc">Édition exclusive</p>
      <a href={`${base}/cigares`} class="link-arrow">En savoir plus</a>
    </div>
    <div class="cigares__img">
      <img src={`${base}/images/hoverla-cigare-gros-plan.jpg`} alt="Cigares Mont Noir" class="img-cover">
    </div>
    <div class="cigares__divider"></div>
  </section>

  <!-- ========================================
       SECTION 6 — COFFRETS
       ======================================== -->
  <section class="coffrets">
    <div class="coffrets__container">
      <div class="coffrets__img-wrapper">
        <img src={`${base}/images/csco-coffrets-cigare.jpg`} alt="Coffrets CSCO">
      </div>
      <h2 class="coffrets__title">COFFRETS<br>D'EXCEPTION</h2>
      <p class="coffrets__desc">L'alliance parfaite entre vodka artisanale et cigares premium. Des coffrets pensés pour les connaisseurs.</p>
      <div class="coffrets__ctas">
        <a href={`${base}/coffrets`} class="btn-primary">Découvrir</a>
        <a href={`${base}/contact`} class="btn-secondary">Nous contacter</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ========================================
     SECTION 1 — HERO ÉDITORIAL
     ======================================== */
  .hero {
    display: grid;
    grid-template-columns: 40vw 1fr;
    height: 100svh;
    background: var(--black);
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 0 80px 10vw;
  }

  .hero__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(56px, 8vw, 88px);
    line-height: 0.85;
    letter-spacing: -0.01em;
    color: var(--white);
    margin-bottom: 20px;
  }

  .hero__subtitle {
    font-family: var(--body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
  }

  .hero__img {
    height: 100%;
    overflow: hidden;
  }

  .hero__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* ========================================
     SECTION 2 — RÉVÉLATION HOVERLA
     ======================================== */
  .revelation {
    display: grid;
    grid-template-columns: 1fr 40%;
    min-height: 70vh;
    background: var(--cream);
  }

  .revelation__text {
    padding: 80px 80px 80px 12vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .revelation__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(64px, 8vw, 96px);
    line-height: 1;
    color: var(--text-dark);
    margin-bottom: 32px;
  }

  .revelation__content p {
    font-family: var(--body);
    font-size: 16px;
    font-weight: 300;
    line-height: 1.9;
    color: var(--text-warm);
    margin-bottom: 32px;
  }

  .link-arrow-gold {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--text-dark);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.3s ease;
  }

  .link-arrow-gold:hover {
    color: var(--gold);
  }

  .link-arrow-gold::after {
    content: '→';
    font-size: 14px;
  }

  .revelation__img {
    height: 100%;
    overflow: hidden;
  }

  .revelation__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ========================================
     SECTION 3 — LA MAISON CSCO
     ======================================== */
  .maison {
    background: var(--black);
    padding: 160px 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .maison__quote {
    font-family: var(--display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1.2;
    color: var(--white);
    max-width: 900px;
    text-align: center;
  }

  /* ========================================
     SECTION 4 — LA GAMME
     ======================================== */
  .gamme {
    background: var(--black);
    padding: 80px 0;
  }

  .gamme__scroll {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 60px 10vw;
    cursor: grab;
  }

  .gamme__scroll::-webkit-scrollbar {
    display: none;
  }

  .gamme__scroll:active {
    cursor: grabbing;
  }

  .gamme__item {
    flex: 0 0 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 40px;
    border-right: 1px solid rgba(200, 168, 78, 0.2);
  }

  .gamme__item:last-child {
    border-right: none;
  }

  .gamme__bottle {
    height: 220px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
    transition: transform 0.5s ease;
  }

  .gamme__item:hover .gamme__bottle {
    transform: translateY(-12px);
  }

  .gamme__item-name {
    font-family: var(--display);
    font-size: 20px;
    font-weight: 300;
    color: var(--white);
    margin-top: 24px;
    letter-spacing: 0.08em;
  }

  .gamme__item-color {
    width: 24px;
    height: 2px;
    margin-top: 8px;
  }

  /* ========================================
     SECTION 5 — CIGARES MONT NOIR
     ======================================== */
  .cigares {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
    background: var(--black-warm);
    position: relative;
  }

  .cigares__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 80px 80px 10vw;
  }

  .cigares__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(56px, 7vw, 72px);
    line-height: 0.95;
    color: var(--white);
    margin-bottom: 20px;
  }

  .cigares__subtitle {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 8px;
  }

  .cigares__desc {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 300;
    color: var(--white-60);
    margin-bottom: 32px;
  }

  .cigares__img {
    height: 100%;
    overflow: hidden;
  }

  .cigares__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .cigares__divider {
    position: absolute;
    left: 50%;
    top: 10%;
    bottom: 10%;
    width: 1px;
    background: var(--gold-dim);
  }

  /* ========================================
     SECTION 6 — COFFRETS
     ======================================== */
  .coffrets {
    background: var(--cream);
    padding: 120px 40px;
  }

  .coffrets__container {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .coffrets__img-wrapper {
    width: 110%;
    margin-left: -5%;
    margin-bottom: 48px;
    overflow: hidden;
  }

  .coffrets__img-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .coffrets__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(48px, 6vw, 72px);
    line-height: 1;
    color: var(--text-dark);
    margin-bottom: 24px;
  }

  .coffrets__desc {
    font-family: var(--body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.9;
    color: var(--text-warm);
    margin-bottom: 40px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .coffrets__ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ========================================
     MOBILE RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      position: relative;
    }

    .hero__img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
    }

    .hero__img::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 50%;
      background: linear-gradient(to top, rgba(8, 8, 8, 0.95), transparent);
    }

    .hero__text {
      position: relative;
      z-index: 1;
      padding: 0 32px 60px;
    }

    .revelation {
      grid-template-columns: 1fr;
    }

    .revelation__text {
      padding: 60px 32px;
    }

    .revelation__img {
      min-height: 400px;
    }

    .maison {
      padding: 100px 32px;
    }

    .gamme__scroll {
      padding: 40px 32px;
    }

    .cigares {
      grid-template-columns: 1fr;
    }

    .cigares__text {
      padding: 60px 32px;
    }

    .cigares__img {
      min-height: 400px;
    }

    .cigares__divider {
      display: none;
    }

    .coffrets {
      padding: 80px 32px;
    }

    .coffrets__img-wrapper {
      width: 100%;
      margin-left: 0;
    }

    .coffrets__ctas {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  // Drag-scroll pour la gamme
  const scroll = document.getElementById('gamme-scroll');
  if (scroll) {
    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    scroll.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - scroll.offsetLeft;
      scrollLeft = scroll.scrollLeft;
    });

    scroll.addEventListener('mouseleave', () => {
      isDown = false;
    });

    scroll.addEventListener('mouseup', () => {
      isDown = false;
    });

    scroll.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - scroll.offsetLeft;
      const walk = (x - startX) * 1.5;
      scroll.scrollLeft = scrollLeft - walk;
    });
  }
</script>
