---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Coffrets d'Exception – CSCO" description="Coffrets prestige CSCO alliant vodka HOVERLA et cigares Mont Noir. Sur commande.">
  <Nav />

  <!-- Hero Section -->
  <section class="hero-coffrets">
    <div class="hero-content fade-up">
      <h1>Coffrets d'Exception</h1>
      <p class="hero-subtitle">L'Art de l'Assemblage</p>
    </div>
  </section>

  <!-- Coffrets Section -->
  <section class="coffrets-liste">
    <div class="coffret-item fade-up">
      <div class="coffret-image">
        <img src={base + '/images/csco-coffrets-cigare.jpg'} alt="Coffret Découverte" />
      </div>
      <div class="coffret-details">
        <h2>Coffret Découverte</h2>
        <p class="coffret-desc">Une introduction élégante à l'univers CSCO. Ce coffret réunit une sélection de mignonnettes HOVERLA (3 saveurs) et deux cigares Mont Noir, présentés dans un écrin raffiné.</p>
        
        <div class="coffret-contenu">
          <h3>Contient :</h3>
          <ul>
            <li>3 mignonnettes HOVERLA (Pure, Apple, Peach)</li>
            <li>2 cigares Mont Noir</li>
            <li>Coffret bois gravé CSCO</li>
          </ul>
        </div>

        <p class="disponibilite">Sur commande</p>
      </div>
    </div>

    <div class="coffret-item fade-up reverse">
      <div class="coffret-image">
        <img src={base + '/images/csco-coffret-ouvert.jpg'} alt="Coffret Prestige" />
      </div>
      <div class="coffret-details">
        <h2>Coffret Prestige</h2>
        <p class="coffret-desc">L'excellence absolue. Le coffret Prestige rassemble une bouteille HOVERLA 70cl, une sélection de 5 cigares Mont Noir, et des accessoires de dégustation. L'écrin ultime pour célébrer les grandes occasions.</p>
        
        <div class="coffret-contenu">
          <h3>Contient :</h3>
          <ul>
            <li>1 bouteille HOVERLA 70cl (au choix)</li>
            <li>5 cigares Mont Noir</li>
            <li>Coupe-cigare CSCO</li>
            <li>2 verres à vodka gravés</li>
            <li>Coffret luxe bois & cuir</li>
          </ul>
        </div>

        <p class="disponibilite">Sur commande</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-commande">
    <div class="cta-content fade-up">
      <h2>Offrir l'Excellence</h2>
      <p>Nos coffrets sont composés sur mesure et disponibles sur commande. Contactez-nous pour créer votre coffret personnalisé.</p>
      <a href={base + '/contact'} class="btn">Commander un coffret</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero-coffrets {
    padding: 120px 20px 80px;
    text-align: center;
    background: linear-gradient(135deg, var(--bg) 0%, var(--bg-2) 100%);
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: clamp(18px, 2.5vw, 28px);
    font-style: italic;
    color: var(--white-2);
  }

  .coffrets-liste {
    background: var(--bg);
  }

  .coffret-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 100px;
  }

  .coffret-item:last-child {
    margin-bottom: 0;
  }

  .coffret-item.reverse {
    direction: rtl;
  }

  .coffret-item.reverse > * {
    direction: ltr;
  }

  .coffret-image img {
    width: 100%;
    border: 1px solid var(--border);
  }

  .coffret-details h2 {
    margin-bottom: 20px;
  }

  .coffret-desc {
    margin-bottom: 30px;
    line-height: 1.8;
  }

  .coffret-contenu {
    background: var(--bg-2);
    padding: 25px;
    border-left: 3px solid var(--gold);
    margin-bottom: 30px;
  }

  .coffret-contenu h3 {
    font-size: 18px;
    margin-bottom: 15px;
    color: var(--gold-light);
  }

  .coffret-contenu ul {
    list-style: none;
    padding-left: 0;
  }

  .coffret-contenu ul li {
    padding-left: 25px;
    position: relative;
    margin-bottom: 8px;
    color: var(--white-2);
  }

  .coffret-contenu ul li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--gold);
  }

  .disponibilite {
    font-family: var(--font-display);
    font-size: 18px;
    font-style: italic;
    color: var(--gold);
    margin-top: 20px;
  }

  .cta-commande {
    background: var(--bg-2);
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: 20px;
  }

  .cta-content p {
    max-width: 600px;
    margin: 0 auto 40px;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .coffret-item {
      grid-template-columns: 1fr;
      gap: 30px;
      margin-bottom: 60px;
    }

    .coffret-item.reverse {
      direction: ltr;
    }
  }
</style>
