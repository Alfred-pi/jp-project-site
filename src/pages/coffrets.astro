---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Coffrets d'Exception — CSCO" description="Coffrets prestige alliant vodka HOVERLA et cigares Mont Noir. L'art de l'assemblage.">
  <Nav current={`${base}/coffrets`} />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__content fade-up">
        <span class="label">PRESTIGE</span>
        <h1>Coffrets d'Exception</h1>
        <p class="hero__subtitle">L'union parfaite entre vodka artisanale et cigares premium.</p>
      </div>
    </div>
  </section>

  <!-- Coffret Découverte -->
  <section class="coffret">
    <div class="coffret__grid">
      <div class="coffret__image">
        <img src={`${base}/images/csco-coffrets-cigare.jpg`} alt="Coffret Découverte" />
      </div>
      <div class="coffret__content">
        <span class="label fade-up">COFFRET</span>
        <h2 class="fade-up">Découverte</h2>
        <div class="divider fade-up"></div>
        <p class="fade-up">
          Une introduction élégante à l'univers CSCO. Ce coffret réunit une sélection de mignonnettes HOVERLA (3 saveurs) et deux cigares Mont Noir.
        </p>
        
        <div class="coffret__detail fade-up">
          <h4>Contenu :</h4>
          <ul>
            <li>3 mignonnettes HOVERLA (50ml) : Pure, Apple, Peach</li>
            <li>2 cigares Mont Noir</li>
            <li>Écrin bois laqué noir avec finitions dorées</li>
          </ul>
        </div>

        <p class="coffret__price fade-up">Sur commande</p>
        <a href={`${base}/contact`} class="btn btn-gold fade-up">Commander</a>
      </div>
    </div>
  </section>

  <!-- Coffret Prestige -->
  <section class="coffret coffret--reverse">
    <div class="coffret__grid">
      <div class="coffret__content">
        <span class="label fade-up">COFFRET</span>
        <h2 class="fade-up">Prestige</h2>
        <div class="divider fade-up"></div>
        <p class="fade-up">
          L'excellence en grand format. Une bouteille HOVERLA 70cl au choix, accompagnée de quatre cigares Mont Noir dans un coffret haut de gamme.
        </p>
        
        <div class="coffret__detail fade-up">
          <h4>Contenu :</h4>
          <ul>
            <li>1 bouteille HOVERLA 70cl (saveur au choix)</li>
            <li>4 cigares Mont Noir</li>
            <li>Coffret bois massif doublé velours</li>
            <li>Cave à cigares intégrée</li>
          </ul>
        </div>

        <p class="coffret__price fade-up">Sur commande</p>
        <a href={`${base}/contact`} class="btn btn-gold fade-up">Commander</a>
      </div>
      <div class="coffret__image">
        <img src={`${base}/images/csco-coffret-ouvert.jpg`} alt="Coffret Prestige" />
      </div>
    </div>
  </section>

  <!-- Coffret Collectionneur -->
  <section class="coffret">
    <div class="coffret__grid">
      <div class="coffret__image">
        <img src={`${base}/images/csco-coffret-promo.jpg`} alt="Coffret Collectionneur" />
      </div>
      <div class="coffret__content">
        <span class="label fade-up">COFFRET</span>
        <h2 class="fade-up">Collectionneur</h2>
        <div class="divider fade-up"></div>
        <p class="fade-up">
          La quintessence CSCO. La gamme complète HOVERLA (7 saveurs en 70cl) et une sélection de 10 cigares Mont Noir dans un meuble dédié.
        </p>
        
        <div class="coffret__detail fade-up">
          <h4>Contenu :</h4>
          <ul>
            <li>7 bouteilles HOVERLA 70cl (gamme complète)</li>
            <li>10 cigares Mont Noir</li>
            <li>Meuble bois noble avec compartiments individuels</li>
            <li>Humidificateur intégré pour cigares</li>
            <li>Certificat d'authenticité numéroté</li>
          </ul>
        </div>

        <p class="coffret__price fade-up">Édition limitée — Sur commande</p>
        <a href={`${base}/contact`} class="btn btn-gold fade-up">Commander</a>
      </div>
    </div>
  </section>

  <!-- CTA Personnalisation -->
  <section class="personnalisation section-padding">
    <div class="container container--narrow">
      <div class="personnalisation__content fade-up">
        <span class="label">PERSONNALISATION</span>
        <h2>Coffret Sur Mesure</h2>
        <div class="divider"></div>
        <p>
          Créez votre propre coffret CSCO. Choisissez vos saveurs HOVERLA, le nombre de cigares, et la finition de l'écrin.
        </p>
        <a href={`${base}/contact`} class="btn btn-ghost">Demander un devis</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: var(--bg);
    padding: 200px 0 120px;
    margin-top: 72px;
    text-align: center;
  }

  .hero__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    margin: 16px 0 24px;
  }

  .hero__subtitle {
    font-size: 18px;
    color: var(--white-dim);
  }

  /* ========================================
     SECTION COFFRET
     ======================================== */
  .coffret {
    background: var(--bg);
    padding: 80px 0;
  }

  .coffret:nth-of-type(even) {
    background: var(--bg-warm);
  }

  .coffret__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .coffret--reverse .coffret__grid {
    direction: rtl;
  }

  .coffret--reverse .coffret__content {
    direction: ltr;
  }

  .coffret__image img {
    width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .coffret__content h2 {
    margin: 16px 0 32px;
  }

  .coffret__content p {
    margin-bottom: 24px;
  }

  .coffret__detail {
    background: rgba(255, 255, 255, 0.05);
    padding: 24px;
    border-left: 2px solid var(--gold);
    margin: 32px 0;
  }

  .coffret__detail h4 {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .coffret__detail ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .coffret__detail li {
    font-size: 14px;
    color: var(--white-dim);
    margin-bottom: 8px;
    padding-left: 20px;
    position: relative;
  }

  .coffret__detail li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--gold);
  }

  .coffret__price {
    font-family: var(--font-display);
    font-size: 18px;
    font-style: italic;
    color: var(--gold);
    margin: 24px 0 32px;
  }

  /* ========================================
     SECTION PERSONNALISATION
     ======================================== */
  .personnalisation {
    background: var(--bg-cream);
    text-align: center;
  }

  .personnalisation__content h2 {
    color: var(--bg);
    margin: 16px 0 32px;
  }

  .personnalisation__content .label {
    color: var(--bg-warm);
  }

  .personnalisation__content p {
    color: rgba(13, 10, 6, 0.7);
    margin-bottom: 32px;
  }

  .personnalisation__content .btn {
    color: var(--bg);
    border-color: var(--bg);
  }

  .personnalisation__content .btn:hover {
    background: var(--bg);
    color: var(--bg-cream);
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 1024px) {
    .coffret__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .coffret--reverse .coffret__grid {
      direction: ltr;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 160px 0 80px;
      margin-top: 64px;
    }

    .coffret {
      padding: 60px 0;
    }

    .coffret__grid {
      padding: 0 24px;
    }
  }
</style>
