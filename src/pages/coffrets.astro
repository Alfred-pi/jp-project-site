---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Coffrets d'Exception | CSCO">
  
  <!-- HERO SIMPLE -->
  <section class="hero-simple">
    <div class="hero-simple__content">
      <p class="t-label">Excellence & Élégance</p>
      <div class="divider-gold" style="margin: 32px auto;"></div>
      <h1 class="t-hero">COFFRETS<br>D'EXCEPTION</h1>
      <p class="hero-simple__desc">L'alliance parfaite entre vodka artisanale et cigares premium.</p>
    </div>
  </section>

  <!-- LES COFFRETS -->
  <section class="coffrets-grid">
    <div class="coffrets-grid__container">
      
      <!-- Coffret 1 -->
      <div class="coffret-card">
        <div class="coffret-card__img">
          <img src={`${base}/images/csco-coffrets-cigare.jpg`} alt="Coffret Prestige">
        </div>
        <div class="coffret-card__content">
          <h3>COFFRET PRESTIGE</h3>
          <p>1 bouteille HOVERLA Pure 70cl + 3 cigares Mont Noir + verre gravé + coffret bois premium</p>
          <a href={`${base}/contact`} class="btn-primary">Demander un devis</a>
        </div>
      </div>

      <!-- Coffret 2 -->
      <div class="coffret-card">
        <div class="coffret-card__img">
          <img src={`${base}/images/csco-coffret-ouvert.jpg`} alt="Coffret Découverte">
        </div>
        <div class="coffret-card__content">
          <h3>COFFRET DÉCOUVERTE</h3>
          <p>7 mignonnettes HOVERLA (gamme complète) + 2 cigares Mont Noir + verre gravé + écrin velours</p>
          <a href={`${base}/contact`} class="btn-primary">Demander un devis</a>
        </div>
      </div>

      <!-- Coffret 3 -->
      <div class="coffret-card">
        <div class="coffret-card__img">
          <img src={`${base}/images/hoverla-gamme-bar.jpg`} alt="Coffret Collection">
        </div>
        <div class="coffret-card__content">
          <h3>COFFRET COLLECTION</h3>
          <p>3 bouteilles HOVERLA (Pure, Pineapple, Red Berry) + 6 cigares Mont Noir + coffret bois signature</p>
          <a href={`${base}/contact`} class="btn-primary">Demander un devis</a>
        </div>
      </div>

    </div>
  </section>

  <!-- PERSONNALISATION -->
  <section class="personnalisation">
    <div class="personnalisation__content">
      <h2 class="t-section" style="margin-bottom: 24px;">Coffrets sur mesure</h2>
      <p class="t-body" style="max-width: 700px; margin: 0 auto 40px;">
        Vous souhaitez un coffret personnalisé pour un événement, un cadeau corporate ou une occasion spéciale ?<br>
        Nous créons des coffrets sur mesure adaptés à vos besoins.
      </p>
      <a href={`${base}/contact`} class="btn-secondary">Nous contacter</a>
    </div>
  </section>

</Layout>

<style>
  /* HERO SIMPLE */
  .hero-simple {
    background: var(--black);
    padding: 180px 40px 120px;
    text-align: center;
  }

  .hero-simple__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-simple__desc {
    font-family: var(--body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--white-60);
    margin-top: 32px;
  }

  /* COFFRETS GRID */
  .coffrets-grid {
    background: var(--cream);
    padding: 120px 40px;
  }

  .coffrets-grid__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 60px;
  }

  .coffret-card {
    background: var(--white);
    overflow: hidden;
    transition: transform 0.4s ease;
  }

  .coffret-card:hover {
    transform: translateY(-8px);
  }

  .coffret-card__img {
    width: 100%;
    height: 280px;
    overflow: hidden;
  }

  .coffret-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .coffret-card:hover .coffret-card__img img {
    transform: scale(1.05);
  }

  .coffret-card__content {
    padding: 32px;
    text-align: center;
  }

  .coffret-card__content h3 {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 300;
    color: var(--text-dark);
    margin-bottom: 16px;
  }

  .coffret-card__content p {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-warm);
    margin-bottom: 24px;
  }

  /* PERSONNALISATION */
  .personnalisation {
    background: var(--black);
    padding: 120px 40px;
    text-align: center;
  }

  .personnalisation__content .t-body {
    color: var(--white-60);
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .hero-simple {
      padding: 140px 32px 80px;
    }

    .coffrets-grid {
      padding: 80px 32px;
    }

    .coffrets-grid__container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .personnalisation {
      padding: 80px 32px;
    }
  }
</style>
