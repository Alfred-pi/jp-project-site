---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Caviar — Bientôt Disponible — CSCO" description="Le caviar CSCO arrive prochainement. Excellence et raffinement.">
  <Nav current={`${base}/caviar`} />

  <!-- Coming Soon Full Page -->
  <section class="coming-soon">
    <div class="coming-soon__content fade-up">
      <div class="coming-soon__icon">
        <svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5">
          <circle cx="12" cy="12" r="10"></circle>
          <circle cx="12" cy="12" r="6"></circle>
          <circle cx="12" cy="12" r="2"></circle>
        </svg>
      </div>
      
      <span class="label">PROCHAINEMENT</span>
      <h1>Caviar</h1>
      <div class="divider"></div>
      
      <div class="coming-soon__text">
        <p>
          La Maison CSCO prépare l'arrivée d'une sélection exclusive de caviar d'exception.
        </p>
        <p>
          Une nouvelle dimension du luxe et du raffinement, fidèle à notre exigence d'excellence.
        </p>
      </div>

      <a href={`${base}/contact`} class="btn btn-ghost">Être informé du lancement</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .coming-soon {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 40px;
    margin-top: 72px;
    text-align: center;
  }

  .coming-soon__content {
    max-width: 700px;
  }

  .coming-soon__icon {
    margin-bottom: 40px;
  }

  .coming-soon__icon svg {
    stroke: var(--gold);
    opacity: 0.6;
  }

  .coming-soon h1 {
    margin: 16px 0 32px;
  }

  .coming-soon__text {
    max-width: 600px;
    margin: 40px auto;
  }

  .coming-soon__text p {
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .coming-soon .btn {
    margin-top: 24px;
  }

  @media (max-width: 768px) {
    .coming-soon {
      margin-top: 64px;
      padding: 80px 24px;
    }

    .coming-soon__icon svg {
      width: 80px;
      height: 80px;
    }
  }
</style>
